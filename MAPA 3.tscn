[sub_resource type="GDScript" id="GDScript_0jsfg"]
script/source = "extends Area3D

func _on_input_event(_camera: Node, event: InputEvent, _event_position: Vector3, _normal: Vector3, _shape_idx: int) -> void:
	
	# Comprobamos si el jugador hizo clic izquierdo
	if event is InputEventMouseButton and event.button_index == MOUSE_BUTTON_LEFT and event.pressed:
		
		# ¡MAGIA! Esto abre el navegador con el video
		OS.shell_open(\"https://youtu.be/jpMnmG3gtlM?si=Xiap2nF0bB79wBeN\")
		CerebroMisiones.m3.registrar_clic(\"Binoculares\")
"

